      <column caption='Hospital Name' datatype='string' name='[HOSPITAL_NAME]' role='dimension' type='nominal' />
      <column caption='Linear Mean Value' datatype='real' name='[LINEAR_MEAN_VALUE]' role='measure' type='quantitative' />
      <column caption='Measure End Date' datatype='date' name='[MEASURE_END_DATE]' role='dimension' type='ordinal' />
      <column caption='Measure Id' datatype='string' name='[MEASURE_ID]' role='dimension' type='nominal' />
      <column caption='Measure Sk (Dim Measure Details)' datatype='integer' name='[MEASURE_SK (DIM_MEASURE_DETAILS)]' role='measure' type='quantitative' />
