      <aliases enabled='yes' />
      <column caption='Address' datatype='string' name='[ADDRESS]' role='dimension' type='nominal' />
      <column caption='Answer Percent' datatype='real' name='[ANSWER_PERCENT]' role='measure' type='quantitative' />
      <column caption='City (Dim Hospital Details)' datatype='string' name='[CITY (DIM_HOSPITAL_DETAILS)]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column caption='City' datatype='string' name='[CITY]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column caption='Country Id (Dim Country Details)' datatype='integer' name='[COUNTRY_ID (DIM_COUNTRY_DETAILS)]' role='dimension' type='ordinal' />
      <column caption='Country Id (Dim Hospital Details)' datatype='integer' name='[COUNTRY_ID (DIM_HOSPITAL_DETAILS)]' role='dimension' type='ordinal' />
      <column caption='Country Id' datatype='integer' name='[COUNTRY_ID]' role='dimension' type='ordinal' />
      <column caption='Country Name' datatype='string' name='[COUNTRY_NAME]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='County Name' datatype='string' name='[COUNTY_NAME]' role='dimension' semantic-role='[County].[Name]' type='nominal' />
      <column caption='County by Survey Rank' datatype='boolean' name='[Calculation_5871270030848000]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(AVG([SURVEY_RESPONSE_RATE_PERCENT])) &lt;= [Parameters].[Parameter 2]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Hospital Completed Survey by Rank' datatype='boolean' name='[Calculation_6052552029130753]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([NUMBER_OF_COMPLETED_SURVEYS])) &lt;= [Parameters].[Parameter 2]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Hospital Response Rate Rank' datatype='boolean' name='[Calculation_6052552036487170]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(AVG([SURVEY_RESPONSE_RATE_PERCENT])) &lt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top N All Hospitals Total' datatype='boolean' name='[Calculation_6052552070205444]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([SURVEY_RESPONSE_RATE_PERCENT])) &lt;= [Parameters].[Parameter 3]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='National Avg Response Rate' datatype='real' name='[Calculation_6052552076431365]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [MEASURE_ID] : AVG([SURVEY_RESPONSE_RATE_PERCENT]) }' />
      </column>
      <column caption='Variance from Benchmark' datatype='real' name='[Calculation_6052552076595206]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([SURVEY_RESPONSE_RATE_PERCENT]) - AVG([Calculation_6052552076431365])' />
      </column>
      <column caption='Measure Rank per Hospital' datatype='integer' name='[Calculation_6052552079024135]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(AVG([ANSWER_PERCENT]) + AVG([PATIENT_SURVEY_STAR_RATING]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 10 Hospital by Survey' datatype='boolean' name='[Calculation_6052552087412744]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([NUMBER_OF_COMPLETED_SURVEYS])) &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Hospital Id (Dim Hospital Details)' datatype='integer' name='[HOSPITAL_ID (DIM_HOSPITAL_DETAILS)]' role='dimension' type='ordinal' />
